<!-- 404 Error Page -->
<main style="text-align: center; padding: 100px 40px;">
    <h1 style="font-family: 'Playfair Display', serif; font-size: 6rem; color: var(--primary-blue); margin-bottom: 0;">404</h1>
    <h2 style="font-family: 'Playfair Display', serif; font-size: 2rem; color: var(--text-dark); margin-bottom: 20px;">Page Not Found</h2>
    <p style="font-size: 1.2rem; color: var(--text-dark); margin-bottom: 10px; max-width: 500px; margin-left: auto; margin-right: auto;">
        Sorry, <strong>{{requestedUrl}}</strong> doesn't exist or may have been moved.
    </p>
    <p style="margin-bottom: 40px; color: var(--text-dark);">Let's get you back on track.</p>
    <a href="/" class="cta-button">Back to Home</a>
</main>
